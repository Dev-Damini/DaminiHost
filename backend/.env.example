# ─── DaminiHost Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=4000

# JWT secret — change this to a long random string in production!
JWT_SECRET=daminihost-super-secret-change-me

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# In production on Render, set:
# FRONTEND_URL=https://your-daminihost-frontend.onrender.com
